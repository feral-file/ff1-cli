# Test-only environment for local integration runs.
# Copy to `.env.test` locally and adjust paths as needed.

# Optional override for which dp1 distribution to load (see playlist-signer / playlist-verifier).
# Default dependency is `dp1-js-test@1.0.0` from npm; omit this unless you need a local checkout:
#   DP1_JS=file:///absolute/path/to/dp1-js-checkout
#   (must be a built `dist/index.js` tree when using file:)

# Test fixture config used by the CLI integration tests.
FF1_TEST_CONFIG=tests/fixtures/config.test.json

# Signing key used by the test config.
PLAYLIST_PRIVATE_KEY=YOUR_ED25519_PRIVATE_KEY_BASE64_OR_HEX
PLAYLIST_ROLE=agent
